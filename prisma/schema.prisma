// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

model Org {
  partnerOrgLinks    PartnerLink[] @relation("PartnerOrgLinks")
  dealerPartnerLinks PartnerLink[] @relation("DealerPartnerLinks")

  id         String  @id @default(cuid())
  type       OrgType
  name       String
  clerkOrgId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        UserOrg[]
  deals        Deal[]
  subscription OrgSubscription?

  @@index([type])
}

enum OrgType {
  DEALER
  PARTNER
  INTERNAL
}

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  name        String?
  clerkUserId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgs UserOrg[]
}

model UserOrg {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
  @@index([orgId])
  @@index([userId])
}

enum Role {
  OWNER
  GM
  SALES_MANAGER
  SALES
  FINANCE
  COMPLIANCE
  READ_ONLY
}

model Deal {
  id          String     @id @default(cuid())
  orgId       String
  dealNumber  String
  status      DealStatus @default(DRAFT)
  customerRef String?
  vehicleRef  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org            @relation(fields: [orgId], references: [id])
  events   DealEvent[]
  deposits Deposit[]
  evidence EvidenceFile[]
  exports  ExportBundle[]

  @@unique([orgId, dealNumber])
  @@index([orgId, createdAt])
  @@index([orgId, status])
}

enum DealStatus {
  DRAFT
  RESERVED
  DEPOSIT_RECEIVED
  IN_FINANCE
  READY_FOR_TRANSFER
  DELIVERED
  CANCELLED
}

model DealEvent {
  id             String   @id @default(cuid())
  dealId         String
  organizationId String
  type           String
  message        String?
  createdAt      DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId, createdAt])
  @@index([organizationId, createdAt])
}

model Deposit {
  id        String        @id @default(cuid())
  dealId    String
  amount    Int
  currency  String        @default("AED")
  receiptId String        @unique
  status    DepositStatus @default(RECEIVED)
  createdAt DateTime      @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@index([dealId, createdAt])
}

enum DepositStatus {
  RECEIVED
  REFUNDED
  CANCELLED
}

model EvidenceFile {
  id         String   @id @default(cuid())
  dealId     String
  uploadedBy String?
  filename   String
  mimeType   String
  storageKey String
  sha256     String
  redacted   Boolean  @default(false)
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@unique([dealId, storageKey])
  @@index([dealId, createdAt])
}

model ExportBundle {
  id         String   @id @default(cuid())
  dealId     String
  createdBy  String?
  storageKey String
  sha256     String
  createdAt  DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])

  @@unique([dealId, storageKey])
  @@index([dealId, createdAt])
}

model PartnerLink {
  id           String   @id @default(cuid())
  partnerOrgId String
  dealerOrgId  String
  code         String   @unique
  createdAt    DateTime @default(now())

  partnerOrg Org @relation("PartnerOrgLinks", fields: [partnerOrgId], references: [id])
  dealerOrg  Org @relation("DealerPartnerLinks", fields: [dealerOrgId], references: [id])

  @@index([partnerOrgId])
  @@index([dealerOrgId])
}

enum Plan {
  FREE
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model OrgSubscription {
  id    String @id @default(cuid())
  orgId String @unique

  plan   Plan               @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  provider               String? @default("stripe")
  providerCustomerId     String?
  providerSubscriptionId String?

  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}